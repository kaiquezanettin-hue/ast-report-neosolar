{
  "version": 2,
  "builds": [
    { "src": "api/desk-history.js",  "use": "@vercel/node" },
    { "src": "api/desk-ticket.js",   "use": "@vercel/node" },
    { "src": "api/cron-history.js",  "use": "@vercel/node" },
    { "src": "api/index.js",         "use": "@vercel/node" },
    { "src": "public/**",            "use": "@vercel/static" }
  ],
  "crons": [
    {
      "path": "/api/cron-history",
      "schedule": "0 3 * * *"
    }
  ],
  "routes": [
    { "src": "/api/desk-history",  "dest": "/api/desk-history.js" },
    { "src": "/api/desk-ticket",   "dest": "/api/desk-ticket.js" },
    { "src": "/api/cron-history",  "dest": "/api/cron-history.js" },
    { "src": "/api/(.*)",          "dest": "/api/index.js" },
    { "src": "/style.css",         "dest": "/public/style.css" },
    { "src": "/app.js",            "dest": "/public/app.js" },
    { "src": "/(.*)",              "dest": "/public/$1" }
  ]
}
